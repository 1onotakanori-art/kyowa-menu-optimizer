{
  "name": "kyowa-menu-scrape",
  "version": "1.0.0",
  "description": "",
  "main": "scrape.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "scrape": "node prescrap.js",
    "scrape:10": "node prescrap.js 10",
    "scrape:20": "node prescrap.js 20",
    "scrape:upload": "node scrape-and-upload.js",
    "upload": "node upload-to-supabase.js",
    "py": "node scripts/run-python.js",
    "ml:dry-run": "npm run py -- ml/update_weekly.py --dry-run",
    "ml:analyze": "npm run py -- ml/update_weekly.py --skip-retrain",
    "ml:retrain": "npm run py -- ml/menu_recommender.py",
    "ml:regen": "npm run py -- ml/generate_ai_selections.py",
    "ml:regen-only": "npm run py -- ml/update_weekly.py --regen-only",
    "ml:weekly": "npm run py -- ml/update_weekly.py",
    "sync": "npm run upload && npm run ml:regen",
    "weekly": "npm run scrape:upload && npm run ml:weekly",
    "setup:win11": "powershell -ExecutionPolicy Bypass -File scripts/windows/setup-win11.ps1",
    "task:register:win11": "powershell -ExecutionPolicy Bypass -File scripts/windows/register-tasks.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "express": "^4.18.2",
    "node-cron": "^3.0.2",
    "playwright": "^1.57.0"
  }
}
